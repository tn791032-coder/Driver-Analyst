{
  "nbformat": 4,
  "nbformat_minor": 4,
  "metadata": {},
  "cells": [
    {"cell_type": "markdown", "metadata": {}, "source": ["# Demand Forecasting with Prophet\\n", "## Time-series forecast to predict supply-demand gap\\n"]},
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import pandas as pd, numpy as np, matplotlib.pyplot as plt, os\\n",
        "from prophet import Prophet\\n",
        "from sklearn.metrics import mean_absolute_error\\n",
        "plt.rcParams[\\\"figure.figsize\\\"] = (14, 8)\\n",
        "DP = \\\"../data/processed\\\"; DR = \\\"../data/raw\\\"; OUT = \\\"../outputs\\\"\\n",
        "os.makedirs(OUT, exist_ok=True)\\n",
        "df = pd.read_parquet(DP + \\\"/trips_clean.parquet\\\")\\n",
        "zones = pd.read_csv(DR + \\\"/taxi_zone_lookup.csv\\\")\\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "zd = df.groupby(\\\"PULocationID\\\").size().sort_values(ascending=False)\\n",
        "tz = zd.index[0]\\n",
        "zn = zones[zones[\\\"LocationID\\\"]==tz][\\\"Zone\\\"].values[0]\\n",
        "print(f\\\"Top zone: {zn} (ID: {tz})\\")\\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "zdf = df[df[\\\"PULocationID\\\"]==tz].copy()\\n",
        "zdf[\\\"t\\\"] = zdf[\\\"tpep_pickup_datetime\\\"].dt.floor(\\\"h\\\")\\n",
        "hr = zdf.groupby(\\\"t\\\").size().reset_index(name=\\\"demand\\\").sort_values(\\\"t\\\")\\n",
        "print(f\\\"Hours: {len(hr)}\\")\\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "pf = hr.rename(columns={\\\"t\\\":\\\"ds\\\",\\\"demand\\\":\\\"y\\\"})\\n",
        "tr = pf.iloc[:-48]; te = pf.iloc[-48:]\\n",
        "model = Prophet(yearly_seasonality=False, weekly_seasonality=True, daily_seasonality=True)\\n",
        "model.add_seasonality(\\\"hourly\\\", 24, fourier_order=8)\\n",
        "model.fit(tr)\\n",
        "print(\\\"Model trained\\\")\\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "ft = model.make_future_dataframe(48, freq=\\\"h\\\")\\n",
        "fc = model.predict(ft)\\n",
        "fig = model.plot(fc)\\n",
        "plt.title(f\\\"Demand Forecast - {zn}\\")\\n",
        "plt.savefig(OUT + \\\"/forecast.png\\\", dpi=150); plt.show()\\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "model.plot_components(fc)\\n",
        "plt.savefig(OUT + \\\"/forecast_components.png\\\", dpi=150); plt.show()\\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "pred = fc.set_index(\\\"ds\\\").loc[te[\\\"ds\\\"]][\\\"yhat\\\"]\\n",
        "act = te.set_index(\\\"ds\\\")[\\\"y\\\"]\\n",
        "mae = mean_absolute_error(act, pred)\\n",
        "print(f\\\"MAE: {mae:.1f} trips/hr\\\")\\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "fig, ax = plt.subplots(figsize=(14, 5))\\n",
        "ax.plot(act.index, act.values, \\\"b-o\\\", label=\\\"Actual\\\", ms=4)\\n",
        "ax.plot(act.index, pred.values, \\\"r--s\\\", label=\\\"Predicted\\\", ms=4)\\n",
        "ax.legend()\\n",
        "fig.suptitle(f\\\"48h Forecast vs Actual - {zn}\\")\\n",
        "plt.tight_layout(); plt.savefig(OUT + \\\"/forecast_vs_actual.png\\\", dpi=150); plt.show()\\n"
      ]
    },
    {"cell_type": "markdown", "metadata": {}, "source": [
      "## Business Application\\n",
      "1. Driver incentive allocation: predict which zones need more drivers\\n",
      "2. Supply pre-positioning: move drivers before peak\\n",
      "3. Dynamic pricing trigger: activate surge ahead of gap\\n",
      "4. Operational planning: maintenance during low-demand windows\\n"
    ]}
  ]
}
