  "nbformat": 4,
  "nbformat_minor": 4,
  "metadata": {},
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Supply-Demand Gap Analysis for Ride-Hailing\\n",
        "## Adapted for Grab Intern Application - NYC TLC Yellow Taxi Data\\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import pandas as pd\\n",
        "import numpy as np\\n",
        "import matplotlib.pyplot as plt\\n",
        "import seaborn as sns\\n",
        "import os\\n",
        "plt.rcParams.update({\"figure.figsize\": (14, 6), \"font.size\": 12})\\n",
        "sns.set_style(\\\"whitegrid\\\")\\n",
        "DP = \\\"../data/processed\\\"; DR = \\\"../data/raw\\\"; OUT = \\\"../outputs\\\"\\n",
        "os.makedirs(OUT, exist_ok=True)\\n",
        "df = pd.read_parquet(f\\\"{DP}/trips_clean.parquet\\\")\\n",
        "metrics = pd.read_parquet(f\\\"{DP}/supply_demand_metrics.parquet\\\")\\n",
        "zones = pd.read_csv(DR + \\\"/taxi_zone_lookup.csv\\\")\\n",
        "print(f\\\"Trips: {len(df):,} | Metrics: {len(metrics):,} | Zones: {len(zones)}\\")\\n"
      ]
    },
    {"cell_type": "markdown", "metadata": {}, "source": ["## 1. Hourly Demand Pattern\\n"]},
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "ha = df.groupby(\\\"pickup_hour\\\").size() / 7\\n",
        "fig, ax = plt.subplots(figsize=(14, 5))\\n",
        "ax.bar(ha.index, ha.values, color=\\\"#1a73e8\\\", edgecolor=\\\"white\\\")\\n",
        "ax.set(xlabel=\\\"Hour of Day\\\", ylabel=\\\"Avg Requests\\\", title=\\\"Hourly Demand\\\")\\n",
        "ax.set_xticks(range(0, 24))\\n",
        "plt.tight_layout(); plt.savefig(OUT + \\\"/hourly_demand.png\\\", dpi=150); plt.show()\\n"
      ]
    },
    {"cell_type": "markdown", "metadata": {}, "source": ["## 2. Demand-Supply-Gap by Hour\\n"]},
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "hm = metrics.groupby(\\\"hour\\\")[[\\\"demand\\\",\\\"supply\\\",\\\"gap\\\"]].mean()\\n",
        "fig, ax = plt.subplots(figsize=(14, 5))\\n",
        "ax.plot(hm.index, hm[\\\"demand\\\"], \\\"r-o\\\", label=\\\"Demand\\\", linewidth=2)\\n",
        "ax.plot(hm.index, hm[\\\"supply\\\"], \\\"g-s\\\", label=\\\"Supply\\\", linewidth=2)\\n",
        "ax.bar(hm.index, hm[\\\"gap\\\"], alpha=0.3, color=\\\"red\\\", label=\\\"Gap\\\")\\n",
        "ax.set(xlabel=\\\"Hour\\\", ylabel=\\\"Avg\\\", title=\\\"Demand vs Supply by Hour\\\")\\n",
        "ax.legend(); plt.tight_layout(); plt.savefig(OUT + \\\"/demand_supply_gap.png\\\", dpi=150); plt.show()\\n"
      ]
    },
    {"cell_type": "markdown", "metadata": {}, "source": ["## 3. Gap by Borough\\n"]},
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "mz = metrics.merge(zones, left_on=\\\"zone_id\\\", right_on=\\\"LocationID\\\")\\n",
        "bg = mz.groupby(\\\"Borough\\\")[[\\\"demand\\\",\\\"supply\\\",\\\"gap\\\"]].mean()\\n",
        "fig, ax = plt.subplots(figsize=(10, 5))\\n",
        "x = np.arange(len(bg)); w = 0.25\\n",
        "ax.bar(x-w, bg[\\\"demand\\\"], w, label=\\\"Demand\\\", color=\\\"#e74c3c\\\")\\n",
        "ax.bar(x, bg[\\\"supply\\\"], w, label=\\\"Supply\\\", color=\\\"#2ecc71\\\")\\n",
        "ax.bar(x+w, bg[\\\"gap\\\"], w, label=\\\"Gap\\\", color=\\\"#f39c12\\\")\\n",
        "ax.set_xticks(x); ax.set_xticklabels(bg.index, rotation=45)\\n",
        "ax.set_ylabel(\\\"Avg\\\"); ax.set_title(\\\"By Borough\\\")\\n",
        "ax.legend(); plt.tight_layout(); plt.savefig(OUT + \\\"/borough_gap.png\\\", dpi=150); plt.show()\\n"
      ]
    },
    {"cell_type": "markdown", "metadata": {}, "source": ["## 4. Top Undersupplied Zones\\n"]},
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "zs = mz.groupby([\\\"zone_id\\\",\\\"Zone\\\",\\\"Borough\\\"])[[\\\"demand\\\",\\\"supply\\\",\\\"gap\\\",\\\"sdr\\\"]].mean()\\n",
        "bad = zs[zs[\\\"sdr\\\"] < 0.8].sort_values(\\\"gap\\\", ascending=False).head(10)\\n",
        "print(\\\"=== TOP 10 UNDERSUPPLIED ZONES ===\\\")\\n",
        "print(bad.round(1))\\n"
      ]
    },
    {"cell_type": "markdown", "metadata": {}, "source": ["## 5. Key Insights\\n"]},
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "pk = ha.idxmax()\\n",
        "wg = hm.loc[hm[\\\"gap\\\"].idxmax()]\\n",
        "print(f\\\"Peak demand hour: {pk}:00\\\")\\n",
        "print(f\\\"Worst gap hour: {wg.name}:00\\\")\\n",
        "print(f\\\"Worst borough: {bg[\\\\\\\"gap\\\\\\\"].idxmax()}\\")\\n",
        "print(f\\\"Undersupplied: {(metrics[\\\\\\\"sdr\\\\\\\"]<0.8).mean()*100:.1f}%\\\")\\n"
      ]
    }
  ]
}
